{
  "manifest_version": 3,
  "name": "Chrome DOM Bridge MCP",
  "version": "0.1.0",
  "description": "Connects the active Chrome profile to the local DOM bridge helper.",
  "minimum_chrome_version": "116",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Chrome DOM Bridge"
  },
  "permissions": ["alarms", "scripting", "tabs"],
  "host_permissions": ["http://127.0.0.1:9333/*", "ws://127.0.0.1:9333/*", "<all_urls>"]
}
